{
  "expo": {
    "name": "Utsav",
    "slug": "utsav",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "utsav",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.chhavigarg.utsav"
    },
    "android": {
      "package": "com.chhavigarg.utsav",
      "googleServicesFile": "./google-services.json",
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      "expo-splash-screen",
      "expo-image",
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepos": []
          }
        }
      ],
      "@react-native-firebase/app",
      "@react-native-firebase/auth"
    ]
  }
}
